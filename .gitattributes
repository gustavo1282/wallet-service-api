# Padroniza texto em LF no repositório (recomendado)
* text=auto eol=lf

# Scripts sempre em LF (evita quebrar bash)
*.sh text eol=lf

# Docs e configs
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Java
*.java text eol=lf

# Windows-only (se algum dia você tiver)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binários (não mexer)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.jar binary
*.exe binary
*.db binary