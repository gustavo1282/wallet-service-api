{
        "configurations": [
            {
                "type": "java",
                "name": "[k8s] - Wallet Service API",
                "request": "launch",
                "cwd": "${workspaceFolder}",
                "mainClass": "com.guga.walletserviceapi.WalletServiceApplication",
                "projectName": "wallet-service-api",
                //"preLaunchTask": "reset-and-connect-telepresence",
                "args": "",
                "vmArgs": [
                    "-Dspring.profiles.active=k8s",
                    "-javaagent:${workspaceFolder}/lib/opentelemetry-javaagent.jar",
                    "-Dspring.jmx.enabled=false",
                    "-Dspring.boot.admin.client.enabled=false",
                    "-Dspring.devtools.restart.enabled=false",
                    "-Djava.net.preferIPv4Stack=true",
                    "-Dotel.service.name=wallet-service-api",
                    "-Dotel.resource.attributes=service.name=wallet-service-api,environment=env-k8s",
                    "-Dotel.traces.exporter=otlp",
                    "-Dotel.metrics.exporter=otlp",
                    "-Dotel.logs.exporter=otlp",
                    "-Dotel.exporter.otlp.protocol=http/protobuf",
                    "-Dotel.exporter.otlp.timeout=10000",
                    "-Dotel.instrumentation.spring-webmvc.enabled=true",
                    "-Dotel.instrumentation.spring-web.enabled=true",
                    "-Dotel.instrumentation.servlet.enabled=true"
                ],
                "env": {
                    "APP_NAME": "wallet-service-api",
                    "PROFILE": "k8s",
                    "ENV": "env-k8s",
                    "SPRING_PROFILES_ACTIVE": "k8s",
                    "WALLET_USER": "wallet_user",
                    "WALLET_PASS": "wallet_pass",
                    "SPRING_DATASOURCE_PASSWORD": "wallet_pass",
                    "JWT_SECRET": "jwttoken.vault.ks8.239FHF2F923HF9823HF98238F",
                    "VAULT_URI": "http://localhost:8200",
                    "VAULT_TOKEN": "root",
                    "MANAGEMENT_OTLP_ENDPOINT": "http://localhost:4318",
                    "LOGGING_LEVEL_ROOT": "TRACE",
                    "SPRING_CLOUD_VAULT_ENABLED": "true",
                    "SPRING_DATASOURCE_URL": "jdbc:postgresql://localhost:5432/wallet_db",
                    "SERVER_PORT": "8081"
                }
            },
            {
                "type": "java",
                "name": "[test/debug](localhost) - Wallet Service API",
                "request": "launch",
                "cwd": "${workspaceFolder}",
                "mainClass": "com.guga.walletserviceapi.WalletServiceApplication",
                "projectName": "wallet-service-api",
                "args": [
                    "--debug"
                ],
                "vmArgs": [
                    "-Dspring.profiles.active=test",
                    "-Dspring.main.banner-mode=off",
                    "-Dspring.jmx.enabled=false",
                    "-Dspring.boot.admin.client.enabled=false",
                    "-Dspring.devtools.restart.enabled=false",
                    "-Dspring.cloud.vault.enabled=false",
                    "-Djava.net.preferIPv4Stack=true",
                    "-Dotel.sdk.disabled=true"
                ],
                "env": {
                    "APP_NAME": "wallet-service-api",
                    "PROFILE": "test",
                    "ENV": "env-test",
                    "API_PREFIX": "/api/v1",
                    "WALLET_USER": "wallet_user",
                    "WALLET_PASS": "wallet_pass",
                    "JWT_SECRET": "mock.jwt_token.profile_test.859jg89045j9045i",
                    "SONAR_LOCAL_TOKEN": "sqa_26c64d9618282081aa091e3527e728c8a9eadcfc",
                    "MANAGEMENT_OTLP_ENDPOINT": "http://localhost:4318/v1"
                }
            },
            {
                "type": "java",
                "name": "[dev](localhost) - Wallet Service API",
                "request": "launch",
                "cwd": "${workspaceFolder}",
                "mainClass": "com.guga.walletserviceapi.WalletServiceApplication",
                "projectName": "wallet-service-api",
                "args": "",
                //"envFile": "${workspaceFolder}/.env",
                "vmArgs": [
                    "-Dspring.profiles.active=dev",
                    "-Dspring.devtools.add-properties=false",
                    "-javaagent:${workspaceFolder}/lib/opentelemetry-javaagent.jar",
                    "-Dotel.service.name=wallet-service-api",
                    "-Dotel.resource.attributes=service.name=wallet-service-api,environment=env-dev,env=env-dev",
                    "-Dotel.traces.exporter=otlp",
                    "-Dotel.metrics.exporter=otlp",
                    "-Dotel.logs.exporter=otlp",
                    "-Dotel.exporter.otlp.protocol=http/protobuf",
                    // MUDANÇA: Usando o IP que o curl validou
                    "-Dotel.exporter.otlp.endpoint=http://localhost:4318",
                    // ADIÇÃO: Garante que o OkHttp não se perca no IPv6 do Windows
                    "-Djava.net.preferIPv4Stack=true",
                    "-Dotel.exporter.otlp.timeout=10000",
                    "-Dotel.instrumentation.spring-webmvc.enabled=true",
                    "-Dotel.instrumentation.spring-web.enabled=true",
                    "-Dotel.instrumentation.servlet.enabled=true",
                    // INFORMACOES DO VAULT
                    "-Dspring.cloud.vault.enabled=true",
                    "-Dspring.cloud.vault.uri=${VAULT_URI}",
                    "-Dspring.cloud.vault.token=root",
                    "-Dspring.cloud.vault.kv.version=2",
                    "-Dspring.cloud.vault.kv.application-name=wallet-service-api",
                    "-Dspring.cloud.vault.kv.default-context=wallet-service-api",
                    "-Dspring.cloud.vault.kv.profiles=${PROFILE}"
                ],
                "env": {
                    "SPRING_DATASOURCE_PASSWORD": "wallet_pass",
                    "APP_NAME": "wallet-service-api",
                    "PROFILE": "dev",
                    "ENV": "env-dev",
                    "WALLET_USER": "wallet_user",
                    "WALLET_PASS": "wallet_pass",
                    "JWT_SECRET": "mock.jwt_token.profile_dev.hu43oxq",
                    //"MANAGEMENT_OTLP_ENDPOINT": "http://localhost:4318/v1",
                    "SONAR_LOCAL_TOKEN": "sqa_26c64d9618282081aa091e3527e728c8a9eadcfc",
                    "VAULT_URI": "http://localhost:8200",
                    "OTEL_METRICS_EXPORTER": "none",
                    "OTEL_LOGS_EXPORTER": "none",
                    "OTEL_TRACES_EXPORTER": "none",
                    "LOGGING_LEVEL_ROOT": "TRACE"
                }
            }            
  ]
}